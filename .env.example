# ─────────────────────────────────────────────────────────────
# Ride Access NYC — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=https://www.rideaccessnyc.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
WEBHOOK_SECRET=whsec_xxx

# Resend (transactional email)
RESEND_API_KEY=re_xxx
EMAIL_FROM="Ride Access NYC <bookings@rideaccessnyc.com>"
ADMIN_NOTIFY_EMAIL=contact@rideaccessnyc.com

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Live Chat (Tawk.to) — optional
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=19292063210

# Admin dashboard host — optional.
# Set to the subdomain that should serve the admin dashboard, e.g.
# admin.rideaccessnyc.com. When set, /admin is reachable ONLY on this host
# and is redirected off the public domain. Leave blank for local dev
# (the dashboard then stays at /admin on the same host).
NEXT_PUBLIC_ADMIN_HOST=
